{
  fetchFromGitHub,
  buildGo126Module,
  runCommand,
  lib,
  bun,
  nodejs,
  bun2nix,
}:

let
  version = "unstable-2026-05-13";

  src = fetchFromGitHub {
    owner = "wesm";
    repo = "middleman";
    rev = "ab48a4a05ac8684da726bf24a607812290710c47";
    hash = "sha256-0/1hRXuIzuTx0B61SGPANXxI2mdAe/NPH5jDTMVyJ00=";
  };

  patchedSrc = runCommand "middleman-src-with-bun-nix" { } ''
    cp -r ${src} $out
    chmod -R +w $out
    cp ${./bun.nix} $out/bun.nix
  '';

  # pre-fetch bun dependencies using the generated bun.nix
  bunDeps = bun2nix.fetchBunDeps {
    bunNix = "${patchedSrc}/bun.nix"; # generated by running `bun2nix` against the lockfile
  };
in
buildGo126Module {
  pname = "middleman";

  inherit src version;

  vendorHash = "sha256-kPMqE0qHaFfS+cjxQKR92N3aQzI2GBsfgFcgD5lhw9s=";

  nativeBuildInputs = [
    bun
    nodejs
  ];

  preBuild = ''
    # Set up bun cache from pre-fetched deps (what bun2nix.hook would do)
    export BUN_INSTALL_CACHE_DIR=$(mktemp -d)
    cp -r ${bunDeps}/share/bun-cache/. "$BUN_INSTALL_CACHE_DIR"
    export HOME=$(mktemp -d)

    # Install node_modules from cache (no network needed)
    bun install --frozen-lockfile --ignore-scripts

    # Build frontend
    cd frontend && bun run build && cd ..

    # Copy into embed directory
    mkdir -p internal/web/dist
    rm -rf internal/web/dist
    cp -r frontend/dist internal/web/dist
    printf 'ok\n' > internal/web/dist/stub.html
  '';

  subPackages = [ "cmd/middleman" ];
  buildFlags = [ "-trimpath" ];

  ldflags = [
    "-s"
    "-w"
    "-X main.version=${version}"
    "-X main.commit=${src.rev}"
    "-X main.buildDate=1970-01-01T00:00:00Z"
  ];

  meta = with lib; {
    description = "Local-first GitHub dashboard for maintainers to triage, review, and merge PRs and issues across repos";
    homepage = "https://github.com/wesm/middleman";
    license = licenses.mit;
    mainProgram = "middleman";
  };
}
